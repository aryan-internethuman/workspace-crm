# Sync Engine Environment Variables
# Copy this file to .env and fill in your values

# Your Twenty CRM API Key (from Twenty Settings > API & Webhooks > API Keys)
TWENTY_API_KEY=your_api_key_here

# Twenty CRM URL (default: http://localhost:3000)
TWENTY_API_URL=http://localhost:3000/rest

# Redis URL for Celery task queue
REDIS_URL=redis://localhost:6379/0

# Database URL
DATABASE_URL=postgresql://workspace:workspace_password@localhost:5434/workspace_crm
